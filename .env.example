# ═══════════════════════════════════════════════
# MANUAL SYSTEM — Variables de entorno globales
# Copia este archivo como .env y edita los valores
# ═══════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────
POSTGRES_USER=manuals_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_2025
POSTGRES_DB=manuals_db

# ── Redis ───────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── MeiliSearch ─────────────────────────────────
MEILISEARCH_MASTER_KEY=CHANGE_ME_meili_master_key_32chars_minimum

# ── Dominio interno (para CORS, cookies, etc.) ──
APP_DOMAIN=manuals.empresa.local
APP_URL=https://manuals.empresa.local
