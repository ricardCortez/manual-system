# ═══════════════════════════════════════════════
# BACKEND — Variables de entorno
# ═══════════════════════════════════════════════

NODE_ENV=development

# ── App ─────────────────────────────────────────
APP_PORT=3001
APP_HOST=0.0.0.0
APP_URL=https://manuals.empresa.local
APP_NAME="Manual del Sistema"
APP_COMPANY_NAME="Mi Empresa S.A."

# ── Base de datos ────────────────────────────────
DATABASE_URL=postgresql://manuals_user:CHANGE_ME@localhost:5432/manuals_db

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# ── JWT (generar con: openssl genrsa -out private.pem 2048) ──
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── MeiliSearch ──────────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=CHANGE_ME_meili_master_key

# ── Almacenamiento ───────────────────────────────
UPLOAD_BASE_PATH=./uploads
MAX_FILE_SIZE_MB=500
MAX_VIDEO_SIZE_MB=2048
ALLOWED_DOC_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation,image/png,image/jpeg,image/webp,text/markdown

# ── IA — Modo: LOCAL | EXTERNAL | HYBRID ────────
AI_MODE=LOCAL

# IA Local (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_FALLBACK_MODEL=mistral:7b
OLLAMA_TIMEOUT_MS=120000

# IA Externa (OpenAI) — solo en modo EXTERNAL o HYBRID
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_ORG_ID=

# IA Externa (Anthropic) — alternativa a OpenAI
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5-20251001

# Límites IA por usuario
AI_DAILY_SUMMARY_LIMIT=20
AI_DAILY_CHAT_LIMIT=50
AI_MAX_CONCURRENT_JOBS=3

# ── Transcripción (Whisper) ──────────────────────
WHISPER_BIN_PATH=/usr/local/bin/whisper-cpp
WHISPER_MODEL_PATH=./models/ggml-base.en.bin
WHISPER_LANGUAGE=es

# ── Email (opcional, SMTP interno) ───────────────
SMTP_ENABLED=false
SMTP_HOST=mail.empresa.local
SMTP_PORT=587
SMTP_USER=noreply@empresa.local
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM="Manual del Sistema <noreply@empresa.local>"

# ── LibreOffice (conversión DOCX→PDF) ────────────
LIBREOFFICE_BIN=/usr/bin/libreoffice
LIBREOFFICE_TIMEOUT_MS=60000

# ── FFmpeg ───────────────────────────────────────
FFMPEG_BIN=/usr/bin/ffmpeg
FFMPEG_THREADS=4
ADD_GPU_SUPPORT=true
# GPU acceleration: true = auto-detect NVIDIA GPU, false = CPU only
# If GPU detected, uses h264_nvenc codec (5-10x faster encoding)
# Falls back to CPU (libx264) if GPU unavailable

# Video validation constraints
MIN_VIDEO_DURATION_SECS=5
MAX_VIDEO_DURATION_SECS=3600

# Chunked upload settings
VIDEO_CHUNK_SIZE_MB=5
VIDEO_UPLOAD_TIMEOUT_MS=600000

# ── Seguridad ────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
SESSION_SECRET=CHANGE_ME_session_secret_64chars_minimum

# ── BullMQ ───────────────────────────────────────
BULL_BOARD_ENABLED=true
BULL_BOARD_PATH=/admin/queues

# ── Backup ───────────────────────────────────────
BACKUP_PATH=/backups
BACKUP_RETENTION_DAYS=30
