# Environment files
.env
backend/.env
frontend/.env
*.local

# Node modules
node_modules/
backend/node_modules/
frontend/node_modules/

# Build output
backend/dist/
frontend/dist/

# Uploads (user-generated content)
backend/uploads/documents/*
backend/uploads/videos/originals/*
backend/uploads/videos/hls/*
backend/uploads/videos/thumbnails/*
backend/uploads/temp/*
!backend/uploads/**/.gitkeep

# SSL certificates (private keys)
nginx/ssl/*.pem
nginx/ssl/*.key
nginx/ssl/*.crt

# JWT keys
backend/keys/
*.key
*.pub

# Prisma generated client
backend/node_modules/.prisma/

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Claude memory (local only)
.claude/

# Coverage
coverage/
